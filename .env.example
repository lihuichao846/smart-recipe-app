# OpenAI / Vision Model Configuration
# 如果使用 SiliconFlow (硅基流动)，API Key 可以在 https://cloud.siliconflow.cn/ 获取
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen2-VL-72B-Instruct

# DeepSeek Configuration (用于生成食谱)
# 如果使用 SiliconFlow，通常与 OPENAI_API_KEY 相同
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.siliconflow.cn/v1
DEEPSEEK_MODEL=deepseek-ai/DeepSeek-V3
